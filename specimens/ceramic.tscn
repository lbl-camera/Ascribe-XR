[node name="Specimen" instance=ExtResource("1_72twv")]
display_name = "Ceramic Composite"
thumbnail = ExtResource("2_hq0hf")
story_text = Array[String](["Ceramic Matrix Composites (CMCs) are next-generation materials designed for extreme temperatures and deformations in aerospace and industrial turbine applications. CMCs outperform nickel super-alloys by operating up to 500°F hotter and weighing one-third less, leading to lighter, more efficient engines and reduced emissions. MicroCT volumes are crucial for non-destructively characterizing their 3D microstructure.", "Previous work used microCT to investigate CMC microstructure evolution during manufacturing processes like polymer-to-ceramic conversion and fiber impregnation, vital for reinforcement. Samples typically comprise 1012 tows of Hi-Nicalon silicon carbide (SiC) fibers, each with about 500 fibers averaging 6.4 ± 0.9 μm in radius. These fiber beds are approximately 1.5mm wide, containing 5,000-6,200 fibers.", "Although there have been previous semi-supervised fiber detection methods, their computational details are often unavailable. However, Larson et al.'s public data repository has been essential for algorithm development and reproducibility. These microCT images, each about 60 GB and over 14 billion voxels, were acquired at the Advanced Light Source (ALS) at Lawrence Berkeley National Laboratory and are available via the Materials Data Facility. This paper utilizes one of these public volumes and a synthetic dataset, which includes common ringing artifacts inherent in computed-tomography images."])

